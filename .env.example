# PostgreSQL connection string (provided by Railway automatically)
DATABASE_URL=postgresql://user:password@host:5432/mosaicprint

# Image import API keys
PEXELS_API_KEY=your_pexels_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your production domain (for Stripe success/cancel URLs)
BASE_URL=https://your-app.railway.app

# Server port (Railway sets this automatically)
PORT=3000

# Node environment
NODE_ENV=production
