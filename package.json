{
  "name": "mosaicprint",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "pnpm build:client",
    "build:client": "vite build --config client/vite.config.ts",
    "start": "node dist/server/index.js",
    "db:migrate": "node scripts/migrate.mjs",
    "db:import-tiles": "node scripts/import-tiles-from-tidb.mjs",
    "check": "tsc --noEmit",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist/server"
  },
  "dependencies": {
    "@trpc/client": "11.7.2",
    "@trpc/server": "11.7.2",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.7",
    "express": "^4.22.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "sharp": "^0.33.4",
    "stripe": "^16.0.0",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.27.3",
    "mysql2": "^3.11.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "packageManager": "pnpm@9.12.0"
}
